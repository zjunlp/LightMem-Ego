# Em2Mem Online Server environment template.
# Copy to .env and replace placeholder values. Do not commit real secrets.

EM2MEM_API_HOST=127.0.0.1
EM2MEM_API_PORT=8000
EM2MEM_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

EM2MEM_PIPELINE_MODE=mst
EM2MEM_AUTO_PREPROCESS=1
EM2MEM_AUTO_MST_CONSOLIDATION=1
EM2MEM_AUTO_MEMORY=1
EM2MEM_AUTO_VISUAL_EMBEDDING=1

EM2MEM_FRAME_STREAM_MAX_BYTES=8388608
EM2MEM_AUDIO_CHUNK_MAX_BYTES=8388608
EM2MEM_FRAME_STREAM_TARGET_FPS=1
EM2MEM_STREAM_PROCESSING_CHUNK_SECONDS=5
EM2MEM_STREAM_ASR_ENABLED=1
EM2MEM_STREAM_ASR_BACKEND=whisperx

# Rolling ASR for realtime HTTP/live audio chunks.
EM2MEM_AUDIO_ASR_ENABLED=1
EM2MEM_AUDIO_ASR_BACKEND=whisperx
EM2MEM_AUDIO_ASR_WINDOW_MS=5000
EM2MEM_AUDIO_ASR_HOP_MS=5000
EM2MEM_AUDIO_ASR_MIN_WINDOW_MS=4500
EM2MEM_AUDIO_ASR_FLUSH_MIN_MS=2000
EM2MEM_AUDIO_ASR_MAX_WINDOW_MS=7000
EM2MEM_AUDIO_ASR_MAX_PENDING_WINDOWS=3

EM2MEM_FFMPEG_BIN=ffmpeg
EM2MEM_FFPROBE_BIN=ffprobe

EM2MEM_WHISPERX_MODEL=medium
EM2MEM_WHISPERX_DEVICE=cuda
EM2MEM_WHISPERX_COMPUTE_TYPE=float16
EM2MEM_WHISPERX_MODEL_DIR=/path/to/whisperx
EM2MEM_WHISPERX_ALIGN_MODEL_DIR=/path/to/whisperx/alignment
EM2MEM_WHISPERX_ALIGN_LANGS=zh,en

EM2MEM_VISUAL_BACKEND=remote
EM2MEM_VLM2VEC_MODEL_PATH=/path/to/VLM2Vec-V2.0
EM2MEM_VLM2VEC_DEVICE=cuda
EM2MEM_VLM2VEC_DTYPE=float16
EM2MEM_VISUAL_BATCH_SIZE=8
EM2MEM_VLM2VEC_EMBED_HOST=127.0.0.1
EM2MEM_VLM2VEC_EMBED_PORT=18091
EM2MEM_VLM2VEC_EMBED_URL=http://127.0.0.1:18091
EM2MEM_VLM2VEC_EMBED_TIMEOUT_SECONDS=300
EM2MEM_VLM2VEC_EMBED_READY_TIMEOUT_SECONDS=900
EM2MEM_ALLOW_HF_DOWNLOAD=0

EM2MEM_MEMORY_MODEL=gpt-5.4
EM2MEM_QUERY_RESPOND_MODEL=gpt-5.4
EM2MEM_MST_REFINE_MODEL=gpt-5.4
EM2MEM_MST_REFINE_MAX_ATTEMPTS=3
EM2MEM_MST_REFINE_RETRY_BACKOFF_SECONDS=300
EM2MEM_MST_EPISODIC_MODEL=gpt-5.4
EM2MEM_EVIDENCE_CAPTION_BACKEND=openai
EM2MEM_ANSWER_LANGUAGE=zh
EM2MEM_CURRENT_FAST_PATH_ENABLED=1
EM2MEM_MCUR_MAX_QUERY_IMAGES=3
EM2MEM_MCUR_VISUAL_FALLBACK_MAX_IMAGES=3
EM2MEM_MCUR_ANSWER_RETRIES=1
EM2MEM_NORMALIZE_SIMPLIFIED_CHINESE=1
EM2MEM_VOICE_QUESTION_INITIAL_PROMPT=以下是普通话简体中文语音，请输出简体中文。

OPENAI_API_KEY=<your-key>
OPENAI_BASE_URL=<optional-openai-compatible-base-url>

EM2MEM_LIVE_RTMP_ENABLED=0
EM2MEM_LIVE_RTMP_SCHEME=rtmp
EM2MEM_LIVE_RTMP_DOMAIN=localhost
EM2MEM_LIVE_RTMP_PUBLIC_PORT=1935
EM2MEM_LIVE_RTMP_APP=live
EM2MEM_LIVE_RTMP_INTERNAL_PULL_BASE=rtmp://localhost/live
EM2MEM_LIVE_INGEST_FRAME_FPS=1
EM2MEM_LIVE_INGEST_AUDIO_SEGMENT_MS=1500
EM2MEM_LIVE_INGEST_RW_TIMEOUT_US=10000000
EM2MEM_LIVE_INGEST_PROBE_TIMEOUT_SECONDS=10
EM2MEM_LIVE_INGEST_PROBE_RETRY_SECONDS=2
EM2MEM_LIVE_INGEST_ATTEMPT_NO_OUTPUT_SECONDS=25
EM2MEM_LIVE_INGEST_TOTAL_WAIT_SECONDS=90
EM2MEM_ROKID_LIVE_INGEST_RW_TIMEOUT_US=30000000
EM2MEM_ROKID_LIVE_INGEST_STARTUP_WAIT_SECONDS=120
# 0 means keep retrying after at least one Rokid RTMP video frame has been ingested.
EM2MEM_ROKID_LIVE_INGEST_RECOVERY_WAIT_SECONDS=0
# Leave empty when the API, SRS, and workers run on the same server.
EM2MEM_LIVE_PULL_BASE_URL=

EM2MEM_WEBRTC_WHIP_ENABLED=0
EM2MEM_WEBRTC_WHIP_SCHEME=http
EM2MEM_WEBRTC_WHIP_DOMAIN=localhost
EM2MEM_WEBRTC_WHIP_PUBLIC_PORT=1985
EM2MEM_WEBRTC_WHIP_PATH=/rtc/v1/whip/
EM2MEM_WEBRTC_WHIP_APP=live

EM2MEM_SRS_CONTAINER_NAME=em2mem-srs
EM2MEM_SRS_DOCKER_IMAGE=ossrs/srs:5
EM2MEM_SRS_RTMP_PORT=1935
EM2MEM_SRS_HTTP_API_PORT=1985
EM2MEM_SRS_HTTP_SERVER_PORT=8080
EM2MEM_SRS_RTC_UDP_PORT=8000

EM2MEM_ROKID_DAY_SESSION_ENABLED=1
EM2MEM_SINGLE_ACTIVE_SESSION=0
EM2MEM_RUNTIME_ADMIN_TOKEN=<optional-admin-token>
