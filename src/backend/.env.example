# WorldMM Online Server environment template.
# Copy to .env and replace placeholder values. Do not commit real secrets.

WORLDMM_API_HOST=127.0.0.1
WORLDMM_API_PORT=8000
WORLDMM_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

WORLDMM_PIPELINE_MODE=mst
WORLDMM_AUTO_PREPROCESS=1
WORLDMM_AUTO_MST_CONSOLIDATION=1
WORLDMM_AUTO_MEMORY=1
WORLDMM_AUTO_VISUAL_EMBEDDING=1

WORLDMM_FRAME_STREAM_MAX_BYTES=8388608
WORLDMM_AUDIO_CHUNK_MAX_BYTES=8388608
WORLDMM_FRAME_STREAM_TARGET_FPS=1
WORLDMM_STREAM_PROCESSING_CHUNK_SECONDS=5
WORLDMM_STREAM_ASR_ENABLED=1
WORLDMM_STREAM_ASR_BACKEND=whisperx

# Rolling ASR for realtime HTTP/live audio chunks.
WORLDMM_AUDIO_ASR_ENABLED=1
WORLDMM_AUDIO_ASR_BACKEND=whisperx
WORLDMM_AUDIO_ASR_WINDOW_MS=5000
WORLDMM_AUDIO_ASR_HOP_MS=5000
WORLDMM_AUDIO_ASR_MIN_WINDOW_MS=4500
WORLDMM_AUDIO_ASR_FLUSH_MIN_MS=2000
WORLDMM_AUDIO_ASR_MAX_WINDOW_MS=7000
WORLDMM_AUDIO_ASR_MAX_PENDING_WINDOWS=3

WORLDMM_FFMPEG_BIN=ffmpeg
WORLDMM_FFPROBE_BIN=ffprobe

WORLDMM_WHISPERX_MODEL=medium
WORLDMM_WHISPERX_DEVICE=cuda
WORLDMM_WHISPERX_COMPUTE_TYPE=float16
WORLDMM_WHISPERX_MODEL_DIR=/path/to/whisperx
WORLDMM_WHISPERX_ALIGN_MODEL_DIR=/path/to/whisperx/alignment
WORLDMM_WHISPERX_ALIGN_LANGS=zh,en

WORLDMM_VISUAL_BACKEND=remote
WORLDMM_VLM2VEC_MODEL_PATH=/path/to/VLM2Vec-V2.0
WORLDMM_VLM2VEC_DEVICE=cuda
WORLDMM_VLM2VEC_DTYPE=float16
WORLDMM_VISUAL_BATCH_SIZE=8
WORLDMM_VLM2VEC_EMBED_HOST=127.0.0.1
WORLDMM_VLM2VEC_EMBED_PORT=18091
WORLDMM_VLM2VEC_EMBED_URL=http://127.0.0.1:18091
WORLDMM_VLM2VEC_EMBED_TIMEOUT_SECONDS=300
WORLDMM_VLM2VEC_EMBED_READY_TIMEOUT_SECONDS=900
WORLDMM_ALLOW_HF_DOWNLOAD=0

WORLDMM_MEMORY_MODEL=gpt-5.4
WORLDMM_QUERY_RESPOND_MODEL=gpt-5.4
WORLDMM_MST_REFINE_MODEL=gpt-5.4
WORLDMM_MST_REFINE_MAX_ATTEMPTS=3
WORLDMM_MST_REFINE_RETRY_BACKOFF_SECONDS=300
WORLDMM_MST_EPISODIC_MODEL=gpt-5.4
WORLDMM_EVIDENCE_CAPTION_BACKEND=openai
WORLDMM_ANSWER_LANGUAGE=zh
WORLDMM_CURRENT_FAST_PATH_ENABLED=1
WORLDMM_MCUR_MAX_QUERY_IMAGES=3
WORLDMM_MCUR_VISUAL_FALLBACK_MAX_IMAGES=3
WORLDMM_MCUR_ANSWER_RETRIES=1
WORLDMM_NORMALIZE_SIMPLIFIED_CHINESE=1
WORLDMM_VOICE_QUESTION_INITIAL_PROMPT=以下是普通话简体中文语音，请输出简体中文。

OPENAI_API_KEY=<your-key>
OPENAI_BASE_URL=<optional-openai-compatible-base-url>

WORLDMM_LIVE_RTMP_ENABLED=0
WORLDMM_LIVE_RTMP_SCHEME=rtmp
WORLDMM_LIVE_RTMP_DOMAIN=localhost
WORLDMM_LIVE_RTMP_PUBLIC_PORT=1935
WORLDMM_LIVE_RTMP_APP=live
WORLDMM_LIVE_RTMP_INTERNAL_PULL_BASE=rtmp://localhost/live
WORLDMM_LIVE_INGEST_FRAME_FPS=1
WORLDMM_LIVE_INGEST_AUDIO_SEGMENT_MS=1500
WORLDMM_LIVE_INGEST_RW_TIMEOUT_US=10000000
WORLDMM_LIVE_INGEST_PROBE_TIMEOUT_SECONDS=10
WORLDMM_LIVE_INGEST_PROBE_RETRY_SECONDS=2
WORLDMM_LIVE_INGEST_ATTEMPT_NO_OUTPUT_SECONDS=25
WORLDMM_LIVE_INGEST_TOTAL_WAIT_SECONDS=90
WORLDMM_ROKID_LIVE_INGEST_RW_TIMEOUT_US=30000000
WORLDMM_ROKID_LIVE_INGEST_STARTUP_WAIT_SECONDS=120
# 0 means keep retrying after at least one Rokid RTMP video frame has been ingested.
WORLDMM_ROKID_LIVE_INGEST_RECOVERY_WAIT_SECONDS=0
# Leave empty when the API, SRS, and workers run on the same server.
WORLDMM_LIVE_PULL_BASE_URL=

WORLDMM_WEBRTC_WHIP_ENABLED=0
WORLDMM_WEBRTC_WHIP_SCHEME=http
WORLDMM_WEBRTC_WHIP_DOMAIN=localhost
WORLDMM_WEBRTC_WHIP_PUBLIC_PORT=1985
WORLDMM_WEBRTC_WHIP_PATH=/rtc/v1/whip/
WORLDMM_WEBRTC_WHIP_APP=live

WORLDMM_SRS_CONTAINER_NAME=worldmm-srs
WORLDMM_SRS_DOCKER_IMAGE=ossrs/srs:5
WORLDMM_SRS_RTMP_PORT=1935
WORLDMM_SRS_HTTP_API_PORT=1985
WORLDMM_SRS_HTTP_SERVER_PORT=8080
WORLDMM_SRS_RTC_UDP_PORT=8000

WORLDMM_ROKID_DAY_SESSION_ENABLED=1
WORLDMM_SINGLE_ACTIVE_SESSION=0
WORLDMM_RUNTIME_ADMIN_TOKEN=<optional-admin-token>
